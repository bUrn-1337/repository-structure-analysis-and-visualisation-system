# Backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────
# Gemini API key. Obtain from https://aistudio.google.com/
GEMINI_API_KEY=AQ.Ab8RN6JGno0ThM13h_pvAmelKNziAVUARwIN_THJ1X7Hr3DXLw

# ── Optional ──────────────────────────────────────────────────────────────
# Model to use for file explanations (default: gemini-1.5-flash — cheap & fast)
# GEMINI_MODEL=gemini-1.5-flash

# Network bind settings for the dev server (default: 127.0.0.1:8000)
# BIND_HOST=127.0.0.1
# PORT=8000
